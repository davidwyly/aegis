{
  "name": "aegis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev -p 3457",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsc/.tsbuildinfo",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "contracts:compile": "cd blockchain && pnpm compile",
    "contracts:test": "cd blockchain && pnpm test",
    "contracts:export-abi": "node scripts/export-abi.mjs",
    "contracts:deploy:local": "cd blockchain && pnpm exec hardhat run scripts/deploy-local.ts --network localhost",
    "contracts:node": "cd blockchain && pnpm exec hardhat node",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "keeper": "tsx scripts/keeper.ts",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts"
  },
  "dependencies": {
    "@noble/ciphers": "^1.0.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0",
    "@tanstack/react-query": "^5.59.0",
    "@wagmi/connectors": "^5.1.15",
    "@wagmi/core": "^2.13.5",
    "drizzle-orm": "^0.45.2",
    "iron-session": "^8.0.4",
    "next": "14.2.16",
    "postgres": "^3.4.9",
    "react": "^19",
    "react-dom": "^19",
    "server-only": "^0.0.1",
    "siwe": "^3.0.0",
    "viem": "^2.21.28",
    "wagmi": "^2.12.17",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "embedded-postgres": "18.3.0-beta.17",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
