# Postgres (Supabase)
DATABASE_URL=
DIRECT_URL=

# SIWE — generate with `openssl rand -hex 32`
SIWE_SESSION_SECRET=

# App URL — used as the SIWE domain check
NEXT_PUBLIC_APP_URL=http://localhost:3457

# Wallet
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# RPC overrides (optional; falls back to public endpoints)
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
NEXT_PUBLIC_HARDHAT_RPC_URL=http://127.0.0.1:8545

# Deployed Aegis instances
NEXT_PUBLIC_AEGIS_BASE=
NEXT_PUBLIC_AEGIS_BASE_SEPOLIA=
NEXT_PUBLIC_AEGIS_HARDHAT=

# Deployed VaultraAdapter instances (Aegis-side adapter, not Vaultra itself)
NEXT_PUBLIC_VAULTRA_ADAPTER_BASE=
NEXT_PUBLIC_VAULTRA_ADAPTER_BASE_SEPOLIA=
NEXT_PUBLIC_VAULTRA_ADAPTER_HARDHAT=

# The Vaultra contracts the keeper indexes
NEXT_PUBLIC_VAULTRA_BASE=
NEXT_PUBLIC_VAULTRA_BASE_SEPOLIA=
NEXT_PUBLIC_VAULTRA_HARDHAT=

# Eclipse DAO Governance.sol — held as DEFAULT_ADMIN_ROLE + GOVERNANCE_ROLE on Aegis
NEXT_PUBLIC_ECLIPSE_GOVERNANCE_BASE=
NEXT_PUBLIC_ECLIPSE_GOVERNANCE_BASE_SEPOLIA=

# ELCP token addresses (stake denomination)
NEXT_PUBLIC_ELCP_BASE=
NEXT_PUBLIC_ELCP_BASE_SEPOLIA=
NEXT_PUBLIC_ELCP_HARDHAT=

# Keeper-only — private key the keeper signs from to call openCase / openDispute.
# Keep this server-side; never NEXT_PUBLIC_*.
KEEPER_PRIVATE_KEY=

# Admin allowlist for /api/admin/failures POST (mark keeper failures as resolved).
# Comma-separated 0x-addresses (case-insensitive). Unset = nobody can write
# (fail-closed). Reads stay public; only write actions are gated.
AEGIS_ADMIN_ADDRESSES=
